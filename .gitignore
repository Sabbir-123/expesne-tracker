# ==================================================
# SPEAKSPEND - PRODUCTION GITIGNORE
# ==================================================

# --------------------------------------------------
# 1. SECRETS (NEVER COMMIT)
# --------------------------------------------------
.env
.env.*
*.env
*.pem
*.key
google-services.json.backup
GoogleService-Info.plist.backup

# --------------------------------------------------
# 2. FLUTTER GENERATED / BUILD FILES
# --------------------------------------------------
.dart_tool/
.packages
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
**/doc/api/

# --------------------------------------------------
# 3. IDE / EDITOR SETTINGS
# --------------------------------------------------
.vscode/
.idea/
*.iml
*.ipr
*.iws

# --------------------------------------------------
# 4. OS SPECIFIC JUNK
# --------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# --------------------------------------------------
# 5. LOGS & COVERAGE
# --------------------------------------------------
*.log
firebase-debug.log
firestore-debug.log
coverage/

# --------------------------------------------------
# 6. ANDROID SPECIFIC
# --------------------------------------------------
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/build/
android/local.properties
android/key.properties
**/*.keystore
**/*.jks

# --------------------------------------------------
# 7. IOS SPECIFIC
# --------------------------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/App.framework
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/flutter_export_environment.sh
ios/Flutter/flutter_assets/
*.mode1v3
*.mode2v3
*.pbxuser
*.perspectivev3

# --------------------------------------------------
# 8. MACOS SPECIFIC
# --------------------------------------------------
macos/Pods/
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/

# --------------------------------------------------
# 9. WEB SPECIFIC
# --------------------------------------------------
build/web/
